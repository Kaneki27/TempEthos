rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserRole() {
      return getUserData().role;
    }
    
    function isStaff() {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'doctor' || getUserRole() == 'nurse');
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    function isOwnPatient(patientId) {
      return isAuthenticated() && getUserData().linkedId == patientId;
    }

    // Patients: staff can read/write; patient can only read own record (FR-PP-01)
    match /patients/{patientId} {
      allow read: if isStaff() || isOwnPatient(patientId);
      allow write: if isStaff();
    }
    
    // Staff directories
    match /staff/{staffId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Treatments, Diagnoses, Analyses: staff can read/write; patient can read own (FR-PP-01)
    match /treatments/{treatId} {
      allow read: if isStaff() || isOwnPatient(resource.data.patientId);
      allow write: if isStaff();
    }
    
    match /diagnoses/{diagId} {
      allow read: if isStaff() || isOwnPatient(resource.data.patientId);
      allow write: if isStaff();
    }
    
    match /analyses/{anaId} {
      allow read: if isStaff() || isOwnPatient(resource.data.patientId);
      allow write: if isStaff();
    }
    
    // Inventory medicines: all staff can read; only admin writes
    match /medicines/{medId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Ward alerts queue
    match /alerts/{alertId} {
      allow read, write: if isStaff();
    }

    // Audit logs: anyone can append, nobody can update or delete (FR-AUD-03)
    match /auditLogs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // AI Reports: doctors/nurses can read; only server-side writes
    match /aiReports/{reportId} {
      allow read: if isStaff();
      allow write: if false; // Cloud Functions / Server Admin SDK only
    }
  }
}
