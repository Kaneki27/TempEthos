rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // Helper Functions
    // =========================

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      );
    }

    function getUserRole() {
      return userDoc().data.role;
    }

    function isAdmin() {
      return isAuthenticated() &&
             getUserRole() == "admin";
    }

    function isDoctor() {
      return isAuthenticated() &&
             getUserRole() == "doctor";
    }

    function isNurse() {
      return isAuthenticated() &&
             getUserRole() == "nurse";
    }

    function isStaff() {
      return isAdmin() ||
             isDoctor() ||
             isNurse();
    }

    function isClinicalStaff() {
      return isDoctor() ||
             isNurse();
    }

    function isOwnPatient(patientId) {
      return isAuthenticated() &&
             userDoc().data.linkedId == patientId;
    }

    // =========================
    // Users
    // =========================

    match /users/{userId} {

      allow read: if request.auth.uid == userId
                  || isAdmin();

      allow create: if request.auth.uid == userId;

      allow update: if request.auth.uid == userId
                    || isAdmin();

      allow delete: if isAdmin();
    }

    // =========================
    // Patients
    // =========================

    match /patients/{patientId} {

      allow read: if isStaff()
                  || isOwnPatient(patientId);

      allow create: if isStaff();

      allow update: if isStaff();

      allow delete: if isAdmin();
    }

    // =========================
    // Staff
    // =========================

    match /staff/{staffId} {

      allow read: if isStaff();

      allow create: if isAdmin();

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // =========================
    // Treatments
    // =========================

    match /treatments/{treatId} {

      allow read: if isStaff()
                  || isOwnPatient(resource.data.patientId);

      allow create: if isStaff();

      allow update: if isStaff();

      allow delete: if isAdmin();
    }

    // =========================
    // Diagnoses
    // =========================

    match /diagnoses/{diagId} {

      allow read: if isStaff()
                  || isOwnPatient(resource.data.patientId);

      allow create: if isStaff();

      allow update: if isStaff();

      allow delete: if isAdmin();
    }

    // =========================
    // Analyses
    // =========================

    match /analyses/{anaId} {

      allow read: if isStaff()
                  || isOwnPatient(resource.data.patientId);

      allow create: if isStaff();

      allow update: if isStaff();

      allow delete: if isAdmin();
    }

    // =========================
    // Appointments
    // =========================

    match /appointments/{appointmentId} {

      allow read: if isStaff();

      allow create: if isStaff();

      allow update: if isStaff();

      allow delete: if isAdmin();
    }

    // =========================
    // Tasks
    // =========================

    match /tasks/{taskId} {

      allow read: if isStaff();

      allow create: if isStaff();

      allow update: if isStaff();

      allow delete: if isAdmin();
    }

    // =========================
    // Rooms
    // =========================

    match /rooms/{roomId} {

      allow read: if isStaff();

      allow create: if isAdmin();

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // =========================
    // Medicines
    // =========================

    match /medicines/{medId} {

      allow read: if isStaff();

      allow create: if isAdmin();

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // =========================
    // Alerts
    // =========================

    match /alerts/{alertId} {

      allow read: if isStaff();

      allow create: if isStaff();

      allow update: if isStaff();

      allow delete: if isAdmin();
    }

    // =========================
    // Audit Logs
    // =========================

    match /auditLogs/{logId} {

      allow create: if isAuthenticated();

      allow read: if isAdmin();

      allow update, delete: if false;
    }

    // =========================
    // AI Reports
    // =========================

    match /aiReports/{reportId} {

      allow read: if isClinicalStaff();

      allow write: if false;
    }

  }
}
